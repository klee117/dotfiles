#!/usr/bin/env bash
# Usage: tmux-profile <profile> [session-name]
set -euo pipefail

profile="${1:-claude}"
session="${2:-$profile}"

# If the session already exists, just attach/switch to it.
if tmux has-session -t "$session" 2>/dev/null; then
  if [ -n "${TMUX:-}" ]; then
    exec tmux switch-client -t "$session"
  else
    exec tmux attach -t "$session"
  fi
fi

case "$profile" in
  claude)
    # window 0: plain shell
    tmux new-session -d -s "$session" -n main
    # window 1: claude on sonnet (latest)
    tmux new-window -t "$session:1" -n claw-normal  'claude --model claude-sonnet-5 --effort medium'
    # window 2: claude on opus (latest)
    tmux new-window -t "$session:2" -n claw-complex 'claude --model claude-opus-4-8 --effort high'
    # window 3: claude on haiku (latest)
    tmux new-window -t "$session:3" -n claw-quick   'claude --model claude-haiku-4-5-20251001 --effort low'
    # window 4: htop
    tmux new-window -t "$session:4" -n htop 'htop'
    # land on window 0
    tmux select-window -t "$session:0"
    ;;
  opencode)
    # window 0: plain shell
    tmux new-session -d -s "$session" -n main
    # window 1: opencode on qwen3.6-plus
    tmux new-window -t "$session:1" -n qwen 'opencode -m opencode/qwen3.6-plus'
    # window 2: opencode on gpt-5.5 
    tmux new-window -t "$session:2" -n openai 'opencode -m opencode/gpt-5.5'
    # window 3: opencode on deepseek-v4-flash-free
    tmux new-window -t "$session:3" -n deepseek 'opencode -m opencode/deepseek-v4-flash-free'
    # window 4: opencode on gemini-3.5-flash
    tmux new-window -t "$session:4" -n gemini 'opencode -m opencode/gemini-3.5-flash'
    # land on window 0
    tmux select-window -t "$session:0"
    ;;
  codex)
    # window 0: plain shell
    tmux new-session -d -s "$session" -n main
    # window 1: codex with the configured default model
    tmux new-window -t "$session:1" -n mini 'codex'
    # window 2: codex on gpt-5.5
    tmux new-window -t "$session:2" -n gpt55 'codex -m gpt-5.5'
    # land on window 0
    tmux select-window -t "$session:0"
    ;;
  *)
    echo "unknown profile: $profile" >&2
    exit 1
    ;;
esac

# Attach (or switch if already inside tmux)
if [ -n "${TMUX:-}" ]; then
  exec tmux switch-client -t "$session"
else
  exec tmux attach -t "$session"
fi
